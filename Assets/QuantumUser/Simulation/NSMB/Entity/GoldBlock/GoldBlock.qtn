component GoldBlock {
	[ExcludeFromPrototype] EntityRef AttachedTo;
	[ExcludeFromPrototype] int ObjectiveCoinsRemaining;
	[ExcludeFromPrototype] byte Timer;
}

event MarioPlayerPickedUpGoldBlock {
	EntityRef Entity;
	EntityRef GoldBlock;
}

event GoldBlockGeneratedObjectiveCoin {
	EntityRef GoldBlock;
}

event GoldBlockRanOutOfCoins {
	EntityRef GoldBlock;
}

event GoldBlockBrokenByMega {
	EntityRef GoldBlock;
}

synced event GoldBlockLostViaDamage {
	EntityRef GoldBlock;
}